{
  "name": "@ericgallitto/feedback-next-demo",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end demo: widget → HTTP API (SQLite) → MCP server + webhook echo",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
