{
  "name": "@ericgallitto/feedback-react",
  "version": "0.1.0",
  "description": "React widget and hooks for feedback-sdk — pluggable, themeable, framework-agnostic submit",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
