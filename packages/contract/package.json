{
  "name": "@ericgallitto/feedback-contract",
  "version": "0.1.0",
  "description": "Shared types, JSON Schema, and OpenAPI spec for feedback-sdk",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    },
    "./store": {
      "import": "./dist/store.js",
      "types": "./dist/store.d.ts"
    },
    "./openapi.json": "./openapi.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "gen-openapi": "tsx scripts/gen-openapi.ts",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "ajv": "^8.17.1",
    "vitest": "^2.1.8"
  }
}
